// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  candidate    Candidate?
}

model Candidate {
  id              String    @id @default(cuid())
  userId          String?   @unique
  referenceId     String    @unique // CT/DT ID
  name            String
  selectedRole    String    // Ninja/Digital/Prime

  // The 6 simple fields for the dashboard
  campusType      String?   // On Campus / Off Campus
  offerLetterDate DateTime?
  jrsDate         DateTime?
  joiningDate     DateTime?
  ilpAttempted    Int       @default(0)
  bgcStarted      Boolean   @default(false)
  
  claimStatus     String    @default("UNCLAIMED") // UNCLAIMED, CLAIMED, DISPUTED
  user            User?     @relation(fields: [userId], references: [id])
}

model DisputeTicket {
  id              String   @id @default(cuid())
  candidateId     String
  claimantEmail   String
  reason          String
  status          String   @default("OPEN")
}
